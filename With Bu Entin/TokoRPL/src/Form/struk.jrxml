	<parameter name="p_id_transaksi" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT t.id as no_faktur, t.tanggal_transaksi, .i.nama as nama_barang, dt.quantity, i.harga as harga_satuan, dt.subtotal_harga, t.jumlah_item, t.total_harga FROM transaksi t JOIN detail_transaksi dt ON t.id = dt.transaksi_id JOIN item i ON dt.item_id = i.id

WHERE t.id = $P{p_id_transaksi}]]>
	</queryString>
